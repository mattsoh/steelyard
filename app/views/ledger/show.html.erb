<% content_for :title, "Full Ledger — Steelyard" %>

<header id="stats">
  <div class="stat">
    <span class="label">&nbsp;</span>
    <span class="value"><%= link_to "← Back to matcher", organization_matcher_path(organization_id: organization_slug), class: "nav-link" %></span>
  </div>
  <div class="stat">
    <span class="label">&nbsp;</span>
    <span class="value"><%= link_to "Change organization", organizations_path, class: "nav-link" %></span>
  </div>
  <div class="stat">
    <span class="label">Cutoff date</span>
    <span class="value"><select class="cutoff-select" id="cutoff-select" aria-label="Choose cutoff period"></select></span>
  </div>
  <div class="stat">
    <span class="label">Final running balance (approx., this window)</span>
    <span class="value" id="stat-final-balance">—</span>
  </div>
  <div class="stat">
    <span class="label">Total transactions</span>
    <span class="value" id="stat-count">—</span>
  </div>
</header>

<main id="ledger-main" class="legacy-grid">
  <section class="panel" id="panel-ledger">
    <div class="panel-header">
      <h2>Transactions from cutoff, oldest → newest, with running balance</h2>
      <div class="search-group">
        <div class="search-wrap">
          <input type="text" class="search" id="search-ledger" placeholder="Search memo or HCB code…">
          <button type="button" class="search-clear" data-clear-target="search-ledger" aria-label="Clear memo/code search">×</button>
        </div>
        <div class="search-wrap search-wrap-amount">
          <input type="text" class="search search-amount" id="search-ledger-amount" placeholder="Search amount…">
          <button type="button" class="search-clear" data-clear-target="search-ledger-amount" aria-label="Clear amount search">×</button>
        </div>
      </div>
      <div class="date-filter-group">
        <label class="date-filter-label" for="search-ledger-after">After</label>
        <div class="search-wrap search-wrap-date">
          <input type="date" class="search search-date" id="search-ledger-after" aria-label="Filter transactions on or after date">
          <button type="button" class="search-clear" data-clear-target="search-ledger-after" aria-label="Clear after-date filter">×</button>
        </div>
        <label class="date-filter-label" for="search-ledger-before">Before</label>
        <div class="search-wrap search-wrap-date">
          <input type="date" class="search search-date" id="search-ledger-before" aria-label="Filter transactions on or before date">
          <button type="button" class="search-clear" data-clear-target="search-ledger-before" aria-label="Clear before-date filter">×</button>
        </div>
      </div>
      <div class="status-filter">
        <label class="status-toggle status-toggle-matched">
          <input type="checkbox" id="filter-matched" checked>
          Matched
        </label>
        <label class="status-toggle status-toggle-discrepancy">
          <input type="checkbox" id="filter-discrepancy" checked>
          Discrepancy
        </label>
        <label class="status-toggle status-toggle-unmatched">
          <input type="checkbox" id="filter-unmatched" checked>
          Unmatched
        </label>
      </div>
    </div>
    <div class="ledger-table-wrap">
      <table class="ledger-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Memo</th>
            <th class="num">Amount</th>
            <th class="num">Running balance</th>
            <th>User</th>
            <th>Category</th>
          </tr>
        </thead>
        <tbody id="ledger-body">
          <tr><td colspan="6"><div class="empty-msg loading-msg"><span class="loading-spinner"></span>Loading transactions&hellip;</div></td></tr>
        </tbody>
      </table>
    </div>
  </section>
</main>

<div id="detail-modal-overlay" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h3 id="detail-modal-title"></h3>
      <button type="button" id="detail-modal-close" class="modal-close">×</button>
    </div>
    <div class="modal-body" id="detail-modal-body"></div>
  </div>
</div>

<div id="cutoff-modal-overlay" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h3>⚠ Matches span across cutoff</h3>
      <button type="button" id="cutoff-modal-close" class="modal-close">×</button>
    </div>
    <div class="modal-body">
      <p>Moving the cutoff here would split <strong id="cutoff-modal-count">0</strong> confirmed match(es)
       These matches will be undone.</p>
      <div class="cutoff-conflict-list" id="cutoff-modal-list"></div>
      <div class="tray-actions">
        <button type="button" id="cutoff-modal-confirm" class="danger">Change cutoff &amp; remove matches</button>
        <button type="button" id="cutoff-modal-cancel" class="secondary">Cancel</button>
      </div>
    </div>
  </div>
</div>

<% content_for :page_scripts do %>
  <%= javascript_include_tag "legacy/ledger" %>
<% end %>
