<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Steelyard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag asset_path('favicon-light.svg'), rel: 'icon', type: 'image/svg+xml', media: '(prefers-color-scheme: light)' %>

    <%= favicon_link_tag asset_path('favicon-dark.svg'), rel: 'icon', type: 'image/svg+xml', media: '(prefers-color-scheme: dark)' %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <main class="container mx-auto mt-28 px-5 display:flex flex-direction:row">
      <%= yield %>
    </main>
  </body>
</html>
