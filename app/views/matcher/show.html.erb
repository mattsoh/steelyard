<% content_for :title, "Steelyard" %>

<header id="stats">
  <div class="stat" id="load-progress-div" style="display:none">
    <span class="label">&nbsp;</span>
    <span class="value load-progress-overall" id="load-progress-overall"></span>
  </div>
  <div class="stat">
    <span class="label">Cutoff date</span>
    <span class="value"><select class="cutoff-select" id="cutoff-select" aria-label="Choose cutoff period"></select></span>
  </div>
  <div class="stat">
    <span class="label">&nbsp;</span>
    <span class="value"><%= link_to "View full ledger →", organization_ledger_path(organization_id: organization_slug), class: "nav-link" %></span>
  </div>
  <div class="stat">
    <span class="label">&nbsp;</span>
    <span class="value"><%= link_to "Change organization", organizations_path, class: "nav-link" %></span>
  </div>
  <div class="stat">
    <span class="label">Unmatched incoming</span>
    <span class="value" id="stat-in-count">—</span>
  </div>
  <div class="stat">
    <span class="label">Unmatched outgoing</span>
    <span class="value" id="stat-out-count">—</span>
  </div>
  <div class="stat">
    <span class="label">Unmatched in total</span>
    <span class="value" id="stat-in-sum">—</span>
  </div>
  <div class="stat">
    <span class="label">Unmatched out total</span>
    <span class="value" id="stat-out-sum">—</span>
  </div>
  <div class="stat">
    <span class="label">Net (should shrink to current balance)</span>
    <span class="value" id="stat-net">—</span>
  </div>
</header>

<main>
  <section class="panel" id="panel-incoming">
    <div class="panel-header">
      <div class="panel-header-top">
        <h2>Incoming<span class="load-progress" id="progress-incoming"></span></h2>
        <div class="header-actions">
          <select class="sort-select" id="sort-incoming" aria-label="Sort incoming transactions">
            <option value="date-desc">Date ↓</option>
            <option value="date-asc">Date ↑</option>
            <option value="amount-desc">Amount ↓</option>
            <option value="amount-asc">Amount ↑</option>
          </select>
        </div>
      </div>
      <div class="search-group">
        <div class="search-wrap">
          <input type="text" class="search" id="search-incoming" placeholder="Search memo or HCB code…">
          <button type="button" class="search-clear" data-clear-target="search-incoming" aria-label="Clear memo/code search">×</button>
        </div>
        <div class="search-wrap search-wrap-amount">
          <input type="text" class="search search-amount" id="search-incoming-amount" placeholder="Search amount…">
          <button type="button" class="search-clear" data-clear-target="search-incoming-amount" aria-label="Clear amount search">×</button>
        </div>
      </div>
      <div class="date-filter-group">
        <label class="date-filter-label" for="search-incoming-after">After</label>
        <div class="search-wrap search-wrap-date">
          <input type="date" class="search search-date" id="search-incoming-after" aria-label="Filter incoming transactions on or after date">
          <button type="button" class="search-clear" data-clear-target="search-incoming-after" aria-label="Clear after-date filter">×</button>
        </div>
        <label class="date-filter-label" for="search-incoming-before">Before</label>
        <div class="search-wrap search-wrap-date">
          <input type="date" class="search search-date" id="search-incoming-before" aria-label="Filter incoming transactions on or before date">
          <button type="button" class="search-clear" data-clear-target="search-incoming-before" aria-label="Clear before-date filter">×</button>
        </div>
      </div>
    </div>
    <div class="list" id="list-incoming">
      <div class="empty-msg loading-msg"><span class="loading-spinner"></span>Loading transactions&hellip;</div>
    </div>
  </section>

  <section class="panel tray" id="panel-tray">
    <div class="panel-header"><h2>Current match</h2></div>
    <div id="tray-empty" class="tray-empty">Click transactions on the left and/or right to start a match.</div>
    <div id="tray-body" class="tray-body hidden">
      <div class="tray-incoming-list" id="tray-incoming-list"></div>
      <div class="tray-arrow">⚖ should equal ⚖</div>
      <div class="tray-outgoing-list" id="tray-outgoing-list"></div>
      <div class="tray-totals">
        <div>Incoming: <span id="tray-in-amt"></span></div>
        <div>Outgoing selected: <span id="tray-out-amt"></span></div>
        <div id="tray-diff-row">Difference: <span id="tray-diff"></span></div>
      </div>
      <div class="tray-actions">
        <button type="button" id="btn-confirm">Confirm match</button>
        <button type="button" id="btn-cancel" class="secondary">Cancel</button>
      </div>
    </div>
  </section>

  <section class="panel" id="panel-outgoing">
    <div class="panel-header">
      <div class="panel-header-top">
        <h2>Outgoing<span class="load-progress" id="progress-outgoing"></span></h2>
        <div class="header-actions">
          <select class="sort-select" id="sort-outgoing" aria-label="Sort outgoing transactions">
            <option value="date-desc">Date ↓</option>
            <option value="date-asc">Date ↑</option>
            <option value="amount-desc">Amount ↓</option>
            <option value="amount-asc">Amount ↑</option>
          </select>
        </div>
      </div>
      <div class="search-group">
        <div class="search-wrap">
          <input type="text" class="search" id="search-outgoing" placeholder="Search memo or HCB code…">
          <button type="button" class="search-clear" data-clear-target="search-outgoing" aria-label="Clear memo/code search">×</button>
        </div>
        <div class="search-wrap search-wrap-amount">
          <input type="text" class="search search-amount" id="search-outgoing-amount" placeholder="Search amount…">
          <button type="button" class="search-clear" data-clear-target="search-outgoing-amount" aria-label="Clear amount search">×</button>
        </div>
      </div>
      <div class="date-filter-group">
        <label class="date-filter-label" for="search-outgoing-after">After</label>
        <div class="search-wrap search-wrap-date">
          <input type="date" class="search search-date" id="search-outgoing-after" aria-label="Filter outgoing transactions on or after date">
          <button type="button" class="search-clear" data-clear-target="search-outgoing-after" aria-label="Clear after-date filter">×</button>
        </div>
        <label class="date-filter-label" for="search-outgoing-before">Before</label>
        <div class="search-wrap search-wrap-date">
          <input type="date" class="search search-date" id="search-outgoing-before" aria-label="Filter outgoing transactions on or before date">
          <button type="button" class="search-clear" data-clear-target="search-outgoing-before" aria-label="Clear before-date filter">×</button>
        </div>
      </div>
    </div>
    <div class="list" id="list-outgoing">
      <div class="empty-msg loading-msg"><span class="loading-spinner"></span>Loading transactions&hellip;</div>
    </div>
  </section>
</main>

<section id="matches-section-unbalanced">
  <div class="panel-header">
    <h2>Unbalanced matches (<span id="matches-unbalanced-count">0</span>)</h2>
    <button type="button" id="btn-refresh-matches" class="secondary" title="Reload matches without reloading the whole page — useful when someone else is matching at the same time">↻ Refresh matches</button>
  </div>
  <div id="matches-unbalanced-list"></div>
</section>

<section id="matches-section-balanced">
  <div class="panel-header">
    <h2>Balanced matches (<span id="matches-balanced-count">0</span>)</h2>
  </div>
  <div id="matches-balanced-list"></div>
</section>

<div id="detail-modal-overlay" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h3 id="detail-modal-title"></h3>
      <button type="button" id="detail-modal-close" class="modal-close">×</button>
    </div>
    <div class="modal-body" id="detail-modal-body"></div>
  </div>
</div>

<div id="cutoff-modal-overlay" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h3>⚠ Matches span across cutoff</h3>
      <button type="button" id="cutoff-modal-close" class="modal-close">×</button>
    </div>
    <div class="modal-body">
      <p>Moving the cutoff here would split <strong id="cutoff-modal-count">0</strong> confirmed match(es) 
       These matches will be undone.</p>
      <div class="cutoff-conflict-list" id="cutoff-modal-list"></div>
      <div class="tray-actions">
        <button type="button" id="cutoff-modal-confirm" class="danger">Change cutoff &amp; remove matches</button>
        <button type="button" id="cutoff-modal-cancel" class="secondary">Cancel</button>
      </div>
    </div>
  </div>
</div>

<% content_for :page_scripts do %>
  <%= javascript_include_tag "legacy/app" %>
<% end %>
