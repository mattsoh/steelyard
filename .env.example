# Required: HCB OAuth application credentials.
HCB_OAUTH_CLIENT_ID=
HCB_OAUTH_CLIENT_SECRET=
HCB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/hcb/callback

# Optional: defaults to https://hcb.hackclub.com
# HCB_API_BASE_URL=https://hcb.hackclub.com

# Optional: cache TTLs (in seconds unless noted)
# HCB_MEMBERS_CACHE_TTL=60
# HCB_TRANSACTION_CACHE_TTL=1800
# HCB_SINGLE_TRANSACTION_CACHE_TTL=86400
